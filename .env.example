# Mentor AI provider config — server-side only, never exposed to the browser.
# Copy this file to ".env" and fill in a key, then restart `npm run dev`.

# --- Groq (default, free tier) ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional overrides (defaults shown):
# MENTOR_BASE_URL=https://api.groq.com/openai/v1
# MENTOR_MODEL=llama-3.3-70b-versatile

# --- To use xAI Grok instead (paid) ---
# MENTOR_API_KEY=xai-...
# MENTOR_BASE_URL=https://api.x.ai/v1
# MENTOR_MODEL=grok-3

# --- To use Google Gemini (free tier, OpenAI-compatible endpoint) ---
# MENTOR_API_KEY=...
# MENTOR_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# MENTOR_MODEL=gemini-2.0-flash
