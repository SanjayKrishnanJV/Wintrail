{
  "name": "learnflow-ai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:mobile": "vite build --mode mobile",
    "cap:sync": "npx cap sync",
    "cap:ios": "npm run build:mobile && npx cap sync ios && npx cap open ios",
    "cap:android": "npm run build:mobile && npx cap sync android && npx cap open android",
    "cap:add:ios": "npx cap add ios",
    "cap:add:android": "npx cap add android",
    "icons": "node scripts/generate-icons.mjs",
    "dev:ios": "cp capacitor.config.dev.json capacitor.config.json && npx cap sync ios && npx cap open ios",
    "dev:android": "cp capacitor.config.dev.json capacitor.config.json && npx cap sync android && npx cap open android",
    "prod:config": "cp capacitor.config.prod.json capacitor.config.json"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@supabase/supabase-js": "^2.108.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.35.2",
    "vite": "^6.0.7"
  }
}
